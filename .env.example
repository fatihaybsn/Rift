# API Change Radar local settings example
APP_NAME=api_change_radar
ENVIRONMENT=development
DEBUG=false
DOCS_ENABLED=true
LOG_LEVEL=INFO
TRACING_EXPORTER=none
OTLP_ENDPOINT=
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://<db_user>:<db_password>@localhost:5432/api_change_radar
DATABASE_ECHO=false
REQUEST_ID_HEADER=X-Request-ID
ENABLE_LLM_CHANGELOG=false
LLM_LOW_CONFIDENCE_THRESHOLD=0.6
